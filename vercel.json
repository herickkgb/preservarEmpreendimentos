{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/preservar/index.html"
    },
    {
      "source": "/admin",
      "destination": "/preservar/admin.html"
    },
    {
      "source": "/admin.html",
      "destination": "/preservar/admin.html"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/preservar/assets/$1"
    },
    {
      "source": "/styles.css",
      "destination": "/preservar/styles.css"
    },
    {
      "source": "/script.js",
      "destination": "/preservar/script.js"
    },
    {
      "source": "/admin.js",
      "destination": "/preservar/admin.js"
    },
    {
      "source": "/data.js",
      "destination": "/preservar/data.js"
    },
    {
      "source": "/robots.txt",
      "destination": "/preservar/robots.txt"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/preservar/sitemap.xml"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
